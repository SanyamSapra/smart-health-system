PORT=5000
NODE_ENV=production
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=use_a_long_random_secret

# Frontend URL used for CORS
CLIENT_URL=https://smart-health-system-eta.vercel.app

# Email settings
# Recommended for deployment: HTTP API keys avoid SMTP connection timeouts.
BREVO_API_KEY=your_brevo_api_key
# Alternative provider. Leave blank unless using Resend.
RESEND_API_KEY=
SENDER_EMAIL=no-reply@example.com
SENDER_NAME=Smart Health System

# Optional SMTP fallback. Leave blank if using BREVO_API_KEY.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional services
GEMINI_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
DISEASE_PREDICTION_API_URL=https://smart-health-ml.onrender.com
