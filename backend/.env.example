# =========================================
# SMART HEALTH SYSTEM - Environment Variables
# =========================================
# 
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in all YOUR_* placeholders with actual values
# 3. NEVER commit .env to git
# 4. Keep this .env.example file (without secrets) for reference
#
# =========================================

# ---- APPLICATION SETTINGS ----
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ---- DATABASE ----
# MongoDB connection string with credentials
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_here
MONGO_DB_NAME=smart_health
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000

# ---- AUTHENTICATION ----
# Strong random secret for JWT signing (min 32 characters, use: openssl rand -base64 32)
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# ---- EMAIL/SMTP CONFIGURATION ----
# SMTP provider settings (e.g., Brevo, Gmail, SendGrid)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_smtp_username_here
SMTP_PASS=your_smtp_password_here
SENDER_EMAIL=your_email@example.com

# ---- GOOGLE GEMINI AI ----
# Get API key from: https://console.cloud.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.35
GEMINI_MAX_OUTPUT_TOKENS=10000

# ---- CLOUDINARY (Image/File Storage) ----
# Get credentials from: https://cloudinary.com/console/
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ---- AI PREDICTION SERVICES ----
# URLs for external AI prediction microservices
DISEASE_PREDICTION_API_URL=http://localhost:5001/api/predict/symptoms
DISEASE_RECOMMENDATION_API_URL=http://localhost:5001/api/recommendations
